# === Expo app (EXPO_PUBLIC_* may be bundled — anon/publishable only, never service_role) ===
# Copy this file to .env and adjust, or rely on wrangler.toml [vars] + app.config.js fallback.
# Dashboard: Supabase → Project Settings → API → Project URL + anon (or publishable) key.
EXPO_PUBLIC_SUPABASE_URL=https://yzunwqzeqfeemyxpkvto.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_jlLEV02J_-3L-C0VcKVzLA_Lzen8jEJ
# Optional alias if you copied a Next.js .env.local line name:
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# This repo is Expo, not Next.js: do NOT add utils/supabase/server.ts, middleware, or @supabase/ssr unless you add a Next app.
# Primary auth: Supabase Auth (email/password) + auto mm_profiles row (see supabase/migrations/*auth_email*).
# Optional legacy: mm-login Edge Function + roster access key (lib/supabase/mmClient.ts).

# Optional: 64 hex chars for shared map encryption across devices
EXPO_PUBLIC_MM_MAP_SHARED_KEY=

# Optional: base URL of self-hosted SuperMap "situational-awareness-api" (no trailing slash).
# When set, the map may use /api/earthquakes etc. instead of calling USGS directly from the browser.
EXPO_PUBLIC_SUPERMAP_API_URL=

# Optional: your Cloudflare Worker (etc.) base that forwards `/forecast?...` to Open-Meteo so clients do not hit third-party APIs directly.
EXPO_PUBLIC_MM_GEO_PROXY_URL=

# Optional: Cloudflare R2 (S3-compatible) for vault ciphertext — same Cloudflare account/network as Tunnel/Workers; no tunnel needed to reach R2’s API.
# The app runs HeadBucket + CreateBucket when needed, so the vault bucket name below is created automatically if your credentials allow it (MinIO root: yes).
# Endpoint: R2 → Overview → S3 API → `https://<ACCOUNT_ID>.r2.cloudflarestorage.com` (bucket name is separate). CORS must allow your web app origin on the bucket.
# EXPO_PUBLIC_S3_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
# EXPO_PUBLIC_S3_ACCESS_KEY=   # R2 API token access key id
# EXPO_PUBLIC_S3_SECRET_KEY=   # R2 API token secret
# EXPO_PUBLIC_S3_BUCKET=vault
# Optional overrides (defaults work for native R2 API hostname above: region=auto, path-style off):
# EXPO_PUBLIC_S3_REGION=auto
# EXPO_PUBLIC_S3_FORCE_PATH_STYLE=false
# MinIO / other S3 behind a custom host: set EXPO_PUBLIC_S3_REGION=us-east-1 and EXPO_PUBLIC_S3_FORCE_PATH_STYLE=true

# Optional: Socket.io chat microserver (Cloudflare Tunnel) — replaces Supabase for live chat.
EXPO_PUBLIC_CHAT_ENDPOINT=https://chat.cloutyskies.org

# Optional: HTTPS URL for Panic long-press — POST JSON { t, u, lat, lng, ts } then local wipe.
# See docs/distress-webhook-setup.md. Restart `expo start` after changing.
EXPO_PUBLIC_DISTRESS_WEBHOOK_URL=

# === scripts/supabase-bootstrap.sh (CLI) ===
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# === Edge Function `send-decoy-alert` (deploy secrets, not Expo public) ===
# Resend: https://resend.com — set in Dashboard → Edge Functions → Secrets or `supabase secrets set`.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Updates <updates@yourdomain.com>
