# === Expo app (EXPO_PUBLIC_* may be bundled — anon only, never service_role) ===
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: 64 hex chars for shared map encryption across devices
EXPO_PUBLIC_MM_MAP_SHARED_KEY=

# Optional: base URL of self-hosted SuperMap "situational-awareness-api" (no trailing slash).
# When set, the map may use /api/earthquakes etc. instead of calling USGS directly from the browser.
EXPO_PUBLIC_SUPERMAP_API_URL=

# Optional: your Cloudflare Worker (etc.) base that forwards `/forecast?...` to Open-Meteo so clients do not hit third-party APIs directly.
EXPO_PUBLIC_MM_GEO_PROXY_URL=

# Optional: HTTPS URL for Panic long-press — POST JSON { t, u, lat, lng, ts } then local wipe.
# See docs/distress-webhook-setup.md. Restart `expo start` after changing.
EXPO_PUBLIC_DISTRESS_WEBHOOK_URL=

# === scripts/supabase-bootstrap.sh (CLI) ===
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
